{
  "name": "tenantguard-labs",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:secure",
    "test:watch": "vitest",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "dev:secure": "HOST=127.0.0.1 LAB_MODE=false tsx watch src/server.ts",
    "dev:labs": "HOST=127.0.0.1 LAB_MODE=true tsx watch src/server.ts",
    "test:secure": "npm run test:prepare && NODE_ENV=test LAB_MODE=false vitest run",
    "test:labs": "npm run test:prepare && NODE_ENV=test LAB_MODE=true vitest run tests/bola-001.integration.test.ts tests/rbac-001.integration.test.ts tests/mass-001.integration.test.ts tests/workflow-001.integration.test.ts",
    "db:seed": "prisma db seed",
    "db:reset": "tsx scripts/reset-database.ts",
    "test:prepare": "NODE_ENV=test prisma migrate deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "private": "true",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
